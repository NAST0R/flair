# ── Provider attivo ───────────────────────────────────────────────────────────
# 'deepseek' oppure 'openai'
FLAIR_PROVIDER=deepseek

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
# V4 (consigliato): flash = workhorse non-thinking, pro = reasoner per --think.
# Gli alias deepseek-chat/deepseek-reasoner scadono il 2026-07-24: usa i nomi V4.
# Con i modelli V4 il thinking si attiva via parametro (lo fa già flair con --think).
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINK_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=0.0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                       # opzionale (proxy/Azure-compat)
# Default scelti per compromesso spesa/efficacia:
#  - veloce (loop a tool, non-reasoning): gpt-4.1-mini  (~$0.40/$1.60 per 1M)
#  - thinking (--think, reasoning):       gpt-5-mini     (~$0.25/$2.00 per 1M)
# NB: come think model resta su gpt-5 / gpt-5-mini / gpt-5.1 o o3. I modelli
# gpt-5.4+ supportano reasoning+tool solo sulla Responses API, non sulla Chat
# Completions usata qui: useresti il think model SENZA ragionamento col toolset.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_THINK_MODEL=gpt-5-mini
OPENAI_TEMPERATURE=0.0
# reasoning_effort: con --think viene impostato a 'medium' in automatico.
# Sovrascrivi qui (none|minimal|low|medium|high|xhigh, dipende dal modello):
# OPENAI_REASONING_EFFORT=medium

# ── Generazione / loop ────────────────────────────────────────────────────────
FLAIR_MAX_TOKENS=8000
FLAIR_TIMEOUT=300
FLAIR_MAX_STEPS=60
# Streaming della risposta in tempo reale (true/false). --no-stream lo disattiva.
FLAIR_STREAM=true

# ── Gestione del contesto (compaction) ────────────────────────────────────────
# Finestra del modello (token). Oltre questa frazione, il contesto viene compattato.
FLAIR_CONTEXT_WINDOW=120000
FLAIR_COMPACT_RATIO=0.75
# Messaggi recenti tenuti integri quando si compatta.
FLAIR_COMPACT_KEEP=8
# Tetto di token per il riassunto generato durante la compaction.
FLAIR_COMPACT_SUMMARY_MAX=2000

# ── Filesystem / tool ─────────────────────────────────────────────────────────
FLAIR_ROOT=.
FLAIR_READ_MAX=12000
FLAIR_GREP_MAX=6000
FLAIR_CMD_MAX=8000
FLAIR_LISTDIR_MAX=200
FLAIR_SEARCH_MAX=80
FLAIR_SEARCH_SCAN_MAX=200000

# ── Ricerca web (agente generico) ─────────────────────────────────────────────
# Con TAVILY_API_KEY usa Tavily (consigliato); senza, fallback su DuckDuckGo (best-effort).
# TAVILY_API_KEY=tvly-...
FLAIR_WEB_MAX=5

# ── Osservabilità ─────────────────────────────────────────────────────────────
# Cartella per il log di sessione (JSONL) e flair.log. Vuoto = nessun log.
# FLAIR_LOG_DIR=./logs

# ── Sicurezza ─────────────────────────────────────────────────────────────────
# false = chiede conferma per edit/write/run_command (con anteprima diff). true = nessuna conferma.
FLAIR_AUTO_APPROVE=false

# ── Stima costo (USD / 1M token) — default per-modello, sovrascrivibili ───────
# FLAIR_PRICE_CACHE_HIT=0.028
# FLAIR_PRICE_CACHE_MISS=0.28
# FLAIR_PRICE_OUTPUT=0.42
