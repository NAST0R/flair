# ── Active provider ───────────────────────────────────────────────────────────
# 'deepseek' or 'openai'
FLAIR_PROVIDER=deepseek

# ── DeepSeek ──────────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
# V4 (recommended): flash = non-thinking workhorse, pro = reasoner for --think.
# The deepseek-chat/deepseek-reasoner aliases expire on 2026-07-24: use the V4 names.
# On V4 models thinking is enabled via a parameter (flair already does it with --think).
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_THINK_MODEL=deepseek-v4-pro
DEEPSEEK_TEMPERATURE=0.0

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=                       # optional (proxy/Azure-compat)
# Defaults chosen as a cost/effectiveness compromise:
#  - fast (tool loop, non-reasoning): gpt-4.1-mini  (~$0.40/$1.60 per 1M)
#  - thinking (--think, reasoning):   gpt-5-mini     (~$0.25/$2.00 per 1M)
# NB: as the think model stay on gpt-5 / gpt-5-mini / gpt-5.1 or o3. gpt-5.4+
# models support reasoning+tools only on the Responses API, not on the Chat
# Completions API used here: you would get the think model WITHOUT reasoning
# when tools are attached.
OPENAI_MODEL=gpt-4.1-mini
OPENAI_THINK_MODEL=gpt-5-mini
OPENAI_TEMPERATURE=0.0
# reasoning_effort: with --think it is set to 'medium' automatically.
# Override it here (none|minimal|low|medium|high|xhigh, model-dependent):
# OPENAI_REASONING_EFFORT=medium

# ── Generation / loop ─────────────────────────────────────────────────────────
FLAIR_MAX_TOKENS=8000
FLAIR_TIMEOUT=300
FLAIR_MAX_STEPS=60
# Step cap for the explorer sub-agent (`explore` tool, read-only).
FLAIR_EXPLORER_MAX_STEPS=20
# Concurrent tool execution: when the model emits multiple tool calls in one turn and
# they are ALL non-destructive (read-only), they run in parallel (lower latency on
# reads/searches/explore). Batches with destructive tools, or single calls, stay
# sequential. Output is identical (same order): only speed changes. false = old
# sequential behavior.
FLAIR_PARALLEL_TOOLS=true
# Thread cap per parallel batch (avoids flooding the network with too many requests).
FLAIR_PARALLEL_TOOLS_MAX=8
# Real-time response streaming (true/false). --no-stream disables it.
FLAIR_STREAM=true

# ── Context management (compaction) ───────────────────────────────────────────
# Model window (tokens). Past this fraction, the context gets compacted.
FLAIR_CONTEXT_WINDOW=120000
FLAIR_COMPACT_RATIO=0.75
# Recent messages kept intact when compacting.
FLAIR_COMPACT_KEEP=8
# Token cap for the summary generated during compaction.
FLAIR_COMPACT_SUMMARY_MAX=2000
# Compaction stage 0: before the LLM summary, prune (for free) tool outputs that are
# provably superseded — duplicates, reads of files later overwritten, partial reads
# covered by a later full read. true recommended.
FLAIR_COMPACT_PRUNE=true

# ── Filesystem / tools ────────────────────────────────────────────────────────
FLAIR_ROOT=.
FLAIR_READ_MAX=12000
FLAIR_GREP_MAX=6000
FLAIR_CMD_MAX=8000
# Maximum size (chars) of the project map (`repo_map` tool).
FLAIR_REPOMAP_MAX=8000
FLAIR_LISTDIR_MAX=200
FLAIR_SEARCH_MAX=80
FLAIR_SEARCH_SCAN_MAX=200000

# ── Web search (general agent) ────────────────────────────────────────────────
# With TAVILY_API_KEY it uses Tavily (recommended); without, it falls back to
# DuckDuckGo (best-effort).
# TAVILY_API_KEY=tvly-...
FLAIR_WEB_MAX=5

# ── Observability ─────────────────────────────────────────────────────────────
# Folder for the session log (JSONL) and flair.log. Empty = no log.
# FLAIR_LOG_DIR=./logs

# ── Sessions ──────────────────────────────────────────────────────────────────
# Where to save/resume sessions (--session, --continue, /save, /load).
# FLAIR_SESSION_DIR=~/.flair/sessions
# Session memory: durable facts jotted by the agent with the `remember` tool,
# injected into the system prompt (stable prefix → cached: costs almost nothing)
# and saved as a <name>.memory.md sidecar next to the session JSON — a plain-text
# file you can edit by hand. Empty injects nothing; it survives compaction and
# /reset. false = the tool does not exist and nothing is injected.
FLAIR_MEMORY=true
# HARD cap of the memory block in chars (~1k tokens at 4000): past it, `remember`
# refuses with a notice and pruning remains a user choice (/memory).
FLAIR_MEMORY_MAX_CHARS=4000

# ── Safety ────────────────────────────────────────────────────────────────────
# false = ask confirmation for edit/write/run_command (with a diff preview). true = no confirmation.
FLAIR_AUTO_APPROVE=false

# Unattended execution: disables destructive tools entirely (writes/edits/
# commands) in both agents. Ideal for read-only scheduled jobs.
FLAIR_READ_ONLY=false

# HARD session cost cap (USD): past it, the task stops (stopped_reason "budget").
# 0 = no limit. Protects against runaway spend in headless use.
FLAIR_MAX_COST=0.0

# Warn when the estimated session cost exceeds this threshold (USD). 0 = disabled.
# FLAIR_COST_WARN=0.50

# ── Cost estimate (USD / 1M tokens) — per-model defaults, overridable ─────────
# FLAIR_PRICE_CACHE_HIT=0.028
# FLAIR_PRICE_CACHE_MISS=0.28
# FLAIR_PRICE_OUTPUT=0.42
